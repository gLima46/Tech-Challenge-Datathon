# ============================================================================
# Variaveis de ambiente do Datathon Fase 05
# Copie este arquivo para .env (nao commite o .env!) e ajuste os valores
# ============================================================================

# ---- MLflow ----
# URI do servidor de tracking. Se usar docker compose, troque para http://mlflow:5000
MLFLOW_TRACKING_URI=http://localhost:5000

# Nome do modelo registrado no Model Registry (igual ao do model_config.yaml)
MLFLOW_MODEL_NAME=lstm-price-forecaster

# Stage de onde a API carrega: None | Staging | Production | Archived
MLFLOW_MODEL_STAGE=Production

# Identificacao do dono do experimento - vira tag MLflow para auditoria (Gap 05)
MLFLOW_OWNER=grupo-XX

# ---- Serving (FastAPI) ----
# Janela de lookback aceita pela API. Deve bater com features.time_steps
TIME_STEPS=60

# Quantos dias a frente o /predict retorna
FUTURE_DAYS=10

# Chave inicial gerada no startup (em prod usar Redis ou cofre de segredos)
INITIAL_API_KEY=trocar-em-producao

# ---- Backend Keras ----
# Necessario para Keras 3+ saber qual backend usar
KERAS_BACKEND=tensorflow

# ---- Logging ----
LOG_LEVEL=INFO

MLFLOW_MODEL_ALIAS=production
